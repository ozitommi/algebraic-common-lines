%         fprintf('Cluster %d: added best cluster after trying \n',success);
%         success = success + 1;
%         iter = 1;
%         fvalBest = Inf;
%     end
% 
%     if length(ind_rem) <= clust_size
%         R1(end+1) = {ind_rem};
