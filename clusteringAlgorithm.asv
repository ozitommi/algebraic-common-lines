toc

% output = sortrows([convs,fvals,clusters],2);
% output = importdata("output.mat");

R = {};
max_clust = 16;
for i = 1:m-1

    S = best_clusters(1,:);
    idx = 2;

    while length(S) < max_clust

        if ~not(isempty(intersect(S,best_clusters(idx,:))))
            S = union(S,best_clusters(idx,:));
        end

        idx = idx + 1;
    
    end

    best_clusters(any(ismember(best_clusters,S),2),:) = [];
    ind_rem = setdiff(ind_rem,S);
    R(end+1) = {S};

end
R(end+1) = {ind_rem};




clusters = output(:,3:6);
S = {clusters(1,:)};
cluster_tree = {S};
num_clusts = 1;
ind_rem = setdiff(ind_rem,clusters(1,:));
i = 2;
while ~isempty(ind_rem)

    cluster = clusters(i,:);
    R = cluster_tree{i-1};
    S = {};
    for j = 1:length(R)
        if ~isempty(intersect(cluster,R{j}))
            cluster = union(cluster,R{j});
        else
            S(end+1) = R(j);
        end
    end
    S(end+1) = {cluster};
    num_clusts = [num_clusts;length(S)];
    cluster_tree{end+1} = S;
    ind_rem = setdiff(ind_rem,cluster);
    i = i + 1;

end
cluster_tree = cluster_tree';



