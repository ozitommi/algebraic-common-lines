% construct R^(1)
R1 = {};
p = size(C,2);
% p = size(C_true,2);
% sample_size = 16;
% subsample = randperm(p);
% subsample = subsample(1:sample_size);
% C = C_true(s3(subsample),subsample);

n = size(C,2); % number of common lines

ind_rem = 1:p;
% ind_rem = 1:sample_size;
clust_size = 4;

% thresh = 0.001;
% thresh = 0.049187607836541 - 2*0.019074920287184; % when n = 4, NOISE = 0.025
thresh = 0.098517384754784 - 2*0.038116690424327; % when n = 4, NOISE = 0.05
% thresh = 0.147252807987198; % when n = 4, NOISE = 0.075
% thresh = 0.2; % when n = 4, NOISE = 0.1
% thresh = 0.633369109197906 % when n = 7, NOISE = 0.1
